---
import Icon from './Icon.astro';

interface Props {
	githubUrl?: string;
	demoUrl?: string;
	liveUrl?: string;
}

const { githubUrl, demoUrl, liveUrl } = Astro.props;
---

<div class="project-buttons">
	{githubUrl && (
		<a href={githubUrl} target="_blank" rel="noopener noreferrer" class="btn btn-secondary">
			<Icon icon="github-logo" size="1.25rem" />
			<span>View Code</span>
		</a>
	)}
	{demoUrl && (
		<a href={demoUrl} target="_blank" rel="noopener noreferrer" class="btn btn-primary">
			<Icon icon="external-link" size="1.25rem" />
			<span>Check Demo</span>
		</a>
	)}
	{liveUrl && (
		<a href={liveUrl} target="_blank" rel="noopener noreferrer" class="btn btn-primary">
			<Icon icon="external-link" size="1.25rem" />
			<span>Check Live Site</span>
		</a>
	)}
</div>

<style>
.project-buttons {
	display: flex;
	gap: 1rem;
	flex-wrap: wrap;
	margin-top: 2rem;
}

.btn {
	display: inline-flex;
	align-items: center;
	gap: 0.75rem;
	padding: 0.875rem 1.75rem;
	border-radius: 0.5rem;
	font-weight: 600;
	font-size: 1rem;
	text-decoration: none;
	transition: all 0.2s ease;
	border: 1px solid transparent;
}

.btn-primary {
	background: var(--accent-regular);
	color: var(--accent-text-over);
	border-color: var(--accent-regular);
}

.btn-primary:hover {
	background: var(--accent-dark);
	border-color: var(--accent-dark);
	transform: translateY(-2px);
	box-shadow: 0 8px 16px rgba(0, 0, 0, 0.3);
}

.btn-secondary {
	background: transparent;
	color: var(--gray-200);
	border-color: var(--gray-800);
}

.btn-secondary:hover {
	background: var(--gray-900);
	border-color: var(--gray-700);
	transform: translateY(-2px);
	box-shadow: 0 8px 16px rgba(0, 0, 0, 0.2);
}
</style>
