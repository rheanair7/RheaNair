---
import ThemeToggle from './ThemeToggle.astro';

const currentPath = Astro.url.pathname;
const base = import.meta.env.BASE_URL;

const navLinks = [
	{ label: 'Home',  href: base },
	{ label: 'Work',  href: `${base}work/` },
	{ label: 'About', href: `${base}about/` },
];
---

<nav class="site-nav">
	<a class="nav-name" href={base}>Rhea Nair</a>

	<div class="nav-center">
		{navLinks.map(link => (
			<a
				href={link.href}
				class:list={['nav-link', { active: currentPath === link.href }]}
			>
				{link.label}
			</a>
		))}
	</div>

	<div class="nav-right">
		<ThemeToggle />
		<a class="nav-resume" href={`${base}assets/RheaNairResume.pdf`} target="_blank" rel="noopener">
			Resume ↗
		</a>
	</div>
</nav>

<style>
	.site-nav {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 1.25rem 2.5rem;
		border-bottom: 1px solid var(--border-color);
		background: var(--bg-surface);
		position: sticky;
		top: 0;
		z-index: 100;
	}

	.nav-name {
		font-size: 0.8125rem;
		font-weight: 500;
		color: var(--gray-0);
		letter-spacing: 0.3px;
		text-decoration: none;
	}

	.nav-center {
		display: flex;
		gap: 2rem;
	}

	.nav-link {
		font-size: 0.75rem;
		color: var(--gray-400);
		text-decoration: none;
		letter-spacing: 0.2px;
		transition: color var(--theme-transition);
	}

	.nav-link:hover,
	.nav-link.active {
		color: var(--gray-0);
	}

	.nav-right {
		display: flex;
		align-items: center;
		gap: 1.25rem;
	}

	.nav-resume {
		font-size: 0.75rem;
		font-weight: 500;
		color: var(--accent);
		border-bottom: 1.5px solid var(--accent);
		padding-bottom: 1px;
		text-decoration: none;
		transition: color var(--theme-transition);
	}

	.nav-resume:hover {
		color: var(--accent-light);
		border-color: var(--accent-light);
	}

	@media (max-width: 50em) {
		.site-nav {
			padding: 1rem 1.25rem;
		}
		.nav-center {
			gap: 1.25rem;
		}
	}
</style>
