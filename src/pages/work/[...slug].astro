---
import { type CollectionEntry, getCollection } from 'astro:content';

import ContactCTA from '../../components/ContactCTA.astro';
import Hero from '../../components/Hero.astro';
import Icon from '../../components/Icon.astro';
import Pill from '../../components/Pill.astro';
import TechBadge from '../../components/TechBadge.astro';
import ProjectButtons from '../../components/ProjectButtons.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

interface Props {
	entry: CollectionEntry<'work'>;
}

// This is a dynamic route that generates a page for every Markdown file in src/content/
// Read more about dynamic routes and this `getStaticPaths` function in the Astro docs:
// https://docs.astro.build/en/core-concepts/routing/#dynamic-routes
export async function getStaticPaths() {
	const work = await getCollection('work');
	return work.map((entry) => ({
		params: { slug: entry.slug },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
	<div class="stack gap-20">
		<div class="stack gap-15">
			<header>
				<div class="wrapper stack gap-4">
					<a class="back-link" href={import.meta.env.BASE_URL + "work/"}><Icon icon="arrow-left" /> Work</a>

					<div class="project-header">
						<h1 class="project-title">{entry.data.title}</h1>

						{entry.data.tags && (
							<div class="tags">
								{entry.data.tags.map((t) => <Pill>{t}</Pill>)}
							</div>
						)}

						{entry.data.description && (
							<p class="project-description">{entry.data.description}</p>
						)}

						{entry.data.technologies && (
							<div class="tech-section">
								<div class="tech-badges">
									{entry.data.technologies.map((tech: any) => (
										<TechBadge name={tech.name} icon={tech.icon} />
									))}
								</div>
							</div>
						)}
					</div>
				</div>
			</header>
			<main class="wrapper">
				<div class="project-content">
					<Content />
				</div>

				{(entry.data.githubUrl || entry.data.demoUrl || entry.data.liveUrl) && (
					<div class="buttons-wrapper">
						<ProjectButtons
							githubUrl={entry.data.githubUrl}
							demoUrl={entry.data.demoUrl}
							liveUrl={entry.data.liveUrl}
						/>
					</div>
				)}
			</main>
		</div>
		<ContactCTA />
	</div>
</BaseLayout>

<style>
	header {
		padding-bottom: 3rem;
		border-bottom: 1px solid var(--gray-800);
	}

	.back-link {
		display: none;
		color: var(--gray-300);
		text-decoration: none;
		font-size: var(--text-md);
		transition: color 0.2s ease;
	}

	.back-link:hover {
		color: var(--gray-0);
	}

	.project-header {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.project-title {
		font-size: var(--text-4xl);
		font-weight: 700;
		color: var(--gray-0);
		margin: 0;
		line-height: 1.1;
	}

	.tags {
		display: flex;
		gap: 0.5rem;
		flex-wrap: wrap;
	}

	.project-description {
		font-size: var(--text-lg);
		line-height: 1.6;
		color: var(--gray-300);
		max-width: none;
		margin: 0;
	}

	.tech-section {
		margin-top: 0.5rem;
	}

	.tech-badges {
		display: flex;
		gap: 0.75rem;
		flex-wrap: wrap;
	}

	.project-content {
		max-width: none;
		margin-top: 2rem;
	}

	.buttons-wrapper {
		margin-top: 3rem;
		padding-top: 2rem;
		border-top: 1px solid var(--gray-800);
	}

	.project-content > :global(* + *) {
		margin-top: 1rem;
	}

	.project-content :global(h2) {
		margin-top: 3rem;
		margin-bottom: 1rem;
		font-size: var(--text-2xl);
		font-weight: 700;
		color: var(--gray-0);
		padding-bottom: 0.5rem;
		border-bottom: 2px solid var(--accent-dark);
	}

	.project-content :global(h2:first-child) {
		margin-top: 0;
	}

	.project-content :global(h3) {
		margin-top: 2rem;
		margin-bottom: 0.75rem;
		font-size: var(--text-xl);
		font-weight: 600;
		color: var(--gray-100);
	}

	.project-content :global(p) {
		line-height: 1.7;
		color: var(--gray-300);
		font-size: var(--text-md);
	}

	.project-content :global(ul) {
		padding-left: 0;
		list-style: none;
		margin: 1.5rem 0;
	}

	.project-content :global(li) {
		position: relative;
		padding-left: 1.75rem;
		margin-bottom: 1.25rem;
		line-height: 1.7;
		color: var(--gray-300);
	}

	.project-content :global(li::before) {
		content: '▹';
		position: absolute;
		left: 0;
		color: var(--accent-regular);
		font-size: 1.25rem;
		line-height: 1.4;
	}

	.project-content :global(strong) {
		color: var(--gray-100);
		font-weight: 600;
	}

	.project-content :global(img) {
		border-radius: 1rem;
		box-shadow: var(--shadow-md);
		background: var(--gradient-subtle);
		border: 1px solid var(--gray-800);
		margin: 2rem 0;
		width: 100%;
	}

	.project-content :global(blockquote) {
		font-size: var(--text-lg);
		font-family: var(--font-brand);
		font-weight: 600;
		line-height: 1.4;
		padding: 1.5rem;
		padding-inline-start: 1.5rem;
		border-inline-start: 0.25rem solid var(--accent-dark);
		background: var(--gray-999);
		border-radius: 0.5rem;
		color: var(--gray-100);
		margin: 2rem 0;
	}

	.project-content :global(code) {
		background: var(--gray-900);
		padding: 0.2rem 0.4rem;
		border-radius: 0.25rem;
		font-size: 0.9em;
		border: 1px solid var(--gray-800);
	}

	.project-content :global(a) {
		color: var(--accent-regular);
		text-decoration: underline;
		text-decoration-color: transparent;
		text-underline-offset: 0.25em;
		transition: text-decoration-color 0.2s ease;
	}

	.project-content :global(a:hover) {
		text-decoration-color: var(--accent-regular);
	}

	.project-content :global(hr) {
		border: none;
		border-top: 1px solid var(--gray-800);
		margin: 3rem 0;
	}

	@media (min-width: 50em) {
		.back-link {
			display: block;
			align-self: flex-start;
		}

		.project-title {
			font-size: var(--text-5xl);
		}

		.project-description {
			font-size: var(--text-xl);
		}

		.project-content :global(h2) {
			font-size: var(--text-3xl);
		}

		.project-content :global(blockquote) {
			font-size: var(--text-xl);
			padding: 2rem;
		}
	}
</style>
