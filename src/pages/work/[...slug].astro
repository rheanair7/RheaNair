	letter-spacing: 1.2px;
	text-transform: uppercase;
	color: var(--gray-400);
	padding: 0.5rem 0.75rem;
	border-bottom: 1px solid var(--border-color);
}

.cs-body :global(td) {
	padding: 0.6rem 0.75rem;
	color: var(--gray-200);
	border-bottom: 1px solid var(--border-color);
}

@media (max-width: 50em) {
