	margin-bottom: 1.5rem;
}

.cs-body :global(pre code) {
	background: none;
	border: none;
	padding: 0;
	color: var(--gray-100);
	font-size: 0.8125rem;
}

.cs-body :global(blockquote) {
	border-left: 3px solid var(--accent);
	padding-left: 1.25rem;
	margin: 1.5rem 0;
	color: var(--gray-300);
	font-style: italic;
}

.cs-body :global(img) {
	border-radius: 8px;
	border: 1px solid var(--border-color);
	margin: 1.5rem 0;
	width: 100%;
}

.cs-body :global(table) {
	width: 100%;
