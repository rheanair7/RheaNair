.case-study {
	max-width: 72rem;
	margin: 0 auto;
	padding: 0 2.5rem 5rem;
}

/* ── BACK BAR ────────────────────────────────────────────── */
.back-bar {
	padding: 1.5rem 0 0;
}

.back-link {
	font-size: 0.75rem;
	color: var(--gray-400);
	text-decoration: none;
	letter-spacing: 0.2px;
	transition: color var(--theme-transition);
}
.back-link:hover { color: var(--accent); }

/* ── HEADER ──────────────────────────────────────────────── */
.cs-header {
	display: flex;
	flex-direction: column;
	gap: 0.75rem;
	padding: 2.5rem 0;
	border-bottom: 1px solid var(--border-color);
	max-width: 52rem;
}

.cs-tags {
	display: flex;
	gap: 6px;
	flex-wrap: wrap;
	margin-bottom: 1rem;
}

.cs-tag {
	font-size: 0.625rem;
	font-weight: 600;
	letter-spacing: 1.2px;
	padding: 3px 9px;
	border-radius: 3px;
	background: var(--accent-subtle);
	color: var(--accent-dark);
	text-transform: uppercase;
}

.cs-title {
	font-size: clamp(1.5rem, 3vw, 2.25rem);
	font-weight: 500;
	color: var(--gray-0);
	letter-spacing: -0.03em;
	line-height: 1.15;
	margin-bottom: 1rem;
}

.cs-lead {
	font-size: 0.9375rem;
	color: var(--gray-300);
	line-height: 1.75;
	max-width: 44ch;
}



/* ── META STRIP ──────────────────────────────────────────── */
.meta-strip {
	display: flex;
	gap: 3rem;
	align-items: center;
	padding: 1.25rem 0;
	border-bottom: 1px solid var(--border-color);
	flex-wrap: wrap;
}

.meta-item {
	display: flex;
	flex-direction: column;
	gap: 2px;
}

.meta-label {
	font-size: 0.625rem;
	font-weight: 600;
	letter-spacing: 1.5px;
	color: var(--gray-500);
	text-transform: uppercase;
}

.meta-value {
	font-size: 0.8125rem;
	color: var(--gray-200);
}

.meta-link {
	font-size: 0.75rem;
	font-weight: 500;
	color: var(--accent);
	border-bottom: 1.5px solid var(--accent);
	padding-bottom: 1px;
	text-decoration: none;
	transition: color var(--theme-transition);
	margin-top: 4px;
}
.meta-link:hover { color: var(--accent-light); border-color: var(--accent-light); }

.cs-body {
	max-width: 52rem;
	padding-top: 3rem;
}

.cs-body :global(h2) {
	font-size: 0.6875rem;
	font-weight: 600;
	letter-spacing: 2px;
	color: var(--gray-400);
	text-transform: uppercase;
	margin-top: 3rem;
	margin-bottom: 1rem;
	border-bottom: 1px solid var(--border-color);
	padding-bottom: 0.75rem;
}

.cs-body :global(h2:first-child) {
	margin-top: 0;
}

.cs-body :global(p) {
	font-size: 1rem;
	color: var(--gray-200);
	line-height: 1.8;
	margin-bottom: 1.25rem;
}

.cs-body :global(ul),
.cs-body :global(ol) {
	padding-left: 1.25rem;
	margin-bottom: 1.25rem;
}

.cs-body :global(li) {
	font-size: 1rem;
	color: var(--gray-200);
	line-height: 1.75;
	margin-bottom: 0.4rem;
}

.cs-body :global(strong) {
	color: var(--gray-0);
	font-weight: 500;
}

.cs-body :global(code) {
	font-family: var(--font-mono);
	font-size: 0.8125rem;
	background: var(--gray-800);
