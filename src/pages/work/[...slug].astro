---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
	const projects = await getCollection('work');
	return projects.map(project => ({
		params: { slug: project.id.replace(/\.md$/, '') },
		props:  { project },
	}));
}

const { project } = Astro.props;
const { Content } = await render(project);
const base = import.meta.env.BASE_URL;
---

<BaseLayout title={project.data.title} description={project.data.description}>

	<article class="case-study">

		<!-- ── BACK NAV ──────────────────────────────────── -->
		<div class="back-bar">
			<a href={`${base}work/`} class="back-link">← All work</a>
		</div>

		<!-- ── HERO HEADER ───────────────────────────────── -->
		<header class="cs-header">
			<div class="cs-tags">
				{project.data.tags.map(tag => (
					<span class="cs-tag">{tag}</span>
				))}
			</div>
			<h1 class="cs-title">{project.data.title}</h1>
			<p class="cs-lead">{project.data.description}</p>
		</header>

		<!-- ── METADATA STRIP ────────────────────────────── -->
		<div class="meta-strip">
			<div class="meta-item">
				<span class="meta-label">Published</span>
				<span class="meta-value">
					{project.data.publishDate.toLocaleDateString('en-US', {
						month: 'long',
						year: 'numeric',
					})}
				</span>
			</div>
			<div class="meta-item">
				<span class="meta-label">Stack</span>
				<span class="meta-value">{project.data.tags.join(' · ')}</span>
			</div>
			<div class="meta-item">
				<a
					href={`https://github.com/rheanair7`}
					target="_blank"
					rel="noopener"
					class="meta-link"
				>
					GitHub ↗
				</a>
			</div>
		</div>

		<!-- ── CASE STUDY CONTENT ────────────────────────── -->
		<div class="cs-body">
			<Content />
		</div>

		<!-- ── NEXT PROJECT ──────────────────────────────── -->
		<div class="cs-footer">
			<a href={`${base}work/`} class="back-link">← Back to all work</a>
		</div>

	</article>
</BaseLayout>

<style>
.case-study {
	max-width: 72rem;
	margin: 0 auto;
	padding: 0 2.5rem 5rem;
}

/* ── BACK BAR ────────────────────────────────────────────── */
.back-bar {
	padding: 1.5rem 0 0;
}

.back-link {
	font-size: 0.75rem;
	color: var(--gray-400);
	text-decoration: none;
	letter-spacing: 0.2px;
	transition: color var(--theme-transition);
}
.back-link:hover { color: var(--accent); }

/* ── HEADER ──────────────────────────────────────────────── */
.cs-header {
	display: flex;
	flex-direction: column;
	gap: 0.75rem;
	padding: 2.5rem 0;
	border-bottom: 1px solid var(--border-color);
	max-width: 52rem;
}

.cs-tags {
	display: flex;
	gap: 6px;
	flex-wrap: wrap;
	margin-bottom: 1rem;
}

.cs-tag {
	font-size: 0.625rem;
	font-weight: 600;
	letter-spacing: 1.2px;
	padding: 3px 9px;
	border-radius: 3px;
	background: var(--accent-subtle);
	color: var(--accent-dark);
	text-transform: uppercase;
}

.cs-title {
	font-size: clamp(1.5rem, 3vw, 2.25rem);
	font-weight: 500;
	color: var(--gray-0);
	letter-spacing: -0.03em;
	line-height: 1.15;
	margin-bottom: 1rem;
}

.cs-lead {
	font-size: 0.9375rem;
	color: var(--gray-300);
	line-height: 1.75;
	max-width: 44ch;
}



/* ── META STRIP ──────────────────────────────────────────── */
.meta-strip {
	display: flex;
	gap: 3rem;
	align-items: center;
	padding: 1.25rem 0;
	border-bottom: 1px solid var(--border-color);
	flex-wrap: wrap;
}

.meta-item {
	display: flex;
	flex-direction: column;
	gap: 2px;
}

.meta-label {
	font-size: 0.625rem;
	font-weight: 600;
	letter-spacing: 1.5px;
	color: var(--gray-500);
	text-transform: uppercase;
}

.meta-value {
	font-size: 0.8125rem;
	color: var(--gray-200);
}

.meta-link {
	font-size: 0.75rem;
	font-weight: 500;
	color: var(--accent);
	border-bottom: 1.5px solid var(--accent);
	padding-bottom: 1px;
	text-decoration: none;
	transition: color var(--theme-transition);
	margin-top: 4px;
}
.meta-link:hover { color: var(--accent-light); border-color: var(--accent-light); }

.cs-body {
	max-width: 52rem;
	padding-top: 3rem;
}

.cs-body :global(h2) {
	font-size: 0.6875rem;
	font-weight: 600;
	letter-spacing: 2px;
	color: var(--gray-400);
	text-transform: uppercase;
	margin-top: 3rem;
	margin-bottom: 1rem;
	border-bottom: 1px solid var(--border-color);
	padding-bottom: 0.75rem;
}

.cs-body :global(h2:first-child) {
	margin-top: 0;
}

.cs-body :global(p) {
	font-size: 1rem;
	color: var(--gray-200);
	line-height: 1.8;
	margin-bottom: 1.25rem;
}

.cs-body :global(ul),
.cs-body :global(ol) {
	padding-left: 1.25rem;
	margin-bottom: 1.25rem;
}

.cs-body :global(li) {
	font-size: 1rem;
	color: var(--gray-200);
	line-height: 1.75;
	margin-bottom: 0.4rem;
}

.cs-body :global(strong) {
	color: var(--gray-0);
	font-weight: 500;
}

.cs-body :global(code) {
	font-family: var(--font-mono);
	font-size: 0.8125rem;
	background: var(--gray-800);
	color: var(--accent);
	padding: 1px 6px;
	border-radius: 3px;
	border: 1px solid var(--border-color);
}

.cs-body :global(pre) {
	background: var(--bg-dark);
	border: 1px solid var(--border-color);
	border-radius: 8px;
	padding: 1.25rem;
	overflow-x: auto;
	margin-bottom: 1.5rem;
}

.cs-body :global(pre code) {
	background: none;
	border: none;
	padding: 0;
	color: var(--gray-100);
	font-size: 0.8125rem;
}

.cs-body :global(blockquote) {
	border-left: 3px solid var(--accent);
	padding-left: 1.25rem;
	margin: 1.5rem 0;
	color: var(--gray-300);
	font-style: italic;
}

.cs-body :global(img) {
	border-radius: 8px;
	border: 1px solid var(--border-color);
	margin: 1.5rem 0;
	width: 100%;
}

.cs-body :global(table) {
	width: 100%;
	border-collapse: collapse;
	font-size: 0.9rem;
	margin-bottom: 1.5rem;
}

.cs-body :global(th) {
	text-align: left;
	font-size: 0.6875rem;
	font-weight: 600;
	letter-spacing: 1.2px;
	text-transform: uppercase;
	color: var(--gray-400);
	padding: 0.5rem 0.75rem;
	border-bottom: 1px solid var(--border-color);
}

.cs-body :global(td) {
	padding: 0.6rem 0.75rem;
	color: var(--gray-200);
	border-bottom: 1px solid var(--border-color);
}

@media (max-width: 50em) {
	.cs-body {
		padding-top: 2rem;
	}
}

/* ── FOOTER ──────────────────────────────────────────────── */
.cs-footer {
	padding-top: 3rem;
	border-top: 1px solid var(--border-color);
	margin-top: 3rem;
}
</style>
