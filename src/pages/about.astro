---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="About — Rhea Nair" description="About Rhea Nair">

	<div class="about-header">
		<div class="header-left">
			<p class="eyebrow">ABOUT</p>
			<h1 class="about-title">Rhea <span class="accent">Nair.</span></h1>
		</div>
		<div class="header-right">
			<p class="about-tagline">ML Engineer & Data Scientist based in Boulder, CO.</p>
			<div class="contact-row">
				<a href="https://www.linkedin.com/in/rheanair07" target="_blank" rel="noopener" class="contact-link">LinkedIn ↗</a>
				<a href="https://github.com/rheanair7" target="_blank" rel="noopener" class="contact-link">GitHub ↗</a>
				<a href="mailto:rheanair071@gmail.com" class="contact-link">Email ↗</a>
				<a href={`${base}assets/RheaNairResume.pdf`} target="_blank" rel="noopener" class="contact-link accent-link">Resume ↗</a>
			</div>
		</div>
	</div>

	<main class="about-body">

		<!-- ── BACKGROUND ──────────────────────────────────── -->
		<div class="section-grid">
			<div class="section-label-col">
				<p class="section-label">BACKGROUND</p>
			</div>
			<div class="section-content">
				<p class="bio-para">I'm an MS student in Computer Science at CU Boulder, with prior degrees in Business Analytics, Cybersecurity, and Computer Science. My work spans ML research and engineering I've built and analyzed vision models, designed NLP systems, and shipped data infrastructure that people actually use.</p>
				<p class="bio-para">During my co-op at Ascend Cargo Systems, I built their analytics infrastructure from scratch and shipped an agentic AI chatbot that lets non-technical clients query complex logistics data in plain English. Before that, I was doing NLP research at Virginia Tech and multi-agent RL at TIFR Mumbai. The domains have been different but the approach is the same understand the problem deeply before touching the model.</p>
				<p class="bio-para">I'm looking for roles in ML engineering or applied research where I can work across the full stack from understanding why a model fails to making sure it holds up in production.</p>
				<p class="bio-para">When I'm not at my desk I'm usually somewhere outside hiking, exploring a new national park, or planning the next trail. Colorado has been very good for that.</p>
			</div>
		</div>

		<div class="divider"></div>

		<!-- ── EDUCATION ───────────────────────────────────── -->
		<div class="section-grid">
			<div class="section-label-col">
				<p class="section-label">EDUCATION</p>
			</div>
			<div class="section-content">
				<div class="edu-grid">
					<div class="edu-card">
						<p class="edu-date">2025 — 2027</p>
						<p class="edu-school">University of Colorado Boulder</p>
						<p class="edu-degree">MS Computer Science</p>
						<p class="edu-detail">Neural Networks · ML Systems · Data Science</p>
					</div>
					<div class="edu-card">
						<p class="edu-date">2023 — 2025</p>
						<p class="edu-school">Virginia Tech</p>
						<p class="edu-degree">Dual MS — Business Analytics & Cybersecurity</p>
						<p class="edu-detail">CGPA 3.97 / 4.00</p>
					</div>
					<div class="edu-card">
						<p class="edu-date">2019 — 2023</p>
						<p class="edu-school">NMIMS Mumbai</p>
						<p class="edu-degree">BTech Computer Science</p>
						<p class="edu-detail">Honours in Data Science</p>
					</div>
				</div>
			</div>
		</div>

		<div class="divider"></div>

		<!-- ── SKILLS ──────────────────────────────────────── -->
		<div class="section-grid">
			<div class="section-label-col">
				<p class="section-label">SKILLS</p>
			</div>
			<div class="section-content">
				<div class="skills-grid">
					<div class="skill-group">
						<p class="skill-group-label">ML / AI</p>
						<div class="skill-pills">
							<span class="pill">PyTorch</span>
							<span class="pill">HuggingFace</span>
							<span class="pill">BERT</span>
							<span class="pill">BLIP-2</span>
							<span class="pill">XGBoost</span>
							<span class="pill">Scikit-learn</span>
							<span class="pill">Grad-CAM</span>
							<span class="pill">spaCy</span>
							<span class="pill">CLAHE</span>
							<span class="pill">Sentence-Transformers</span>
						</div>
					</div>
					<div class="skill-group">
						<p class="skill-group-label">DATA ENGINEERING</p>
						<div class="skill-pills">
							<span class="pill">SQL</span>
							<span class="pill">MySQL</span>
							<span class="pill">PostgreSQL</span>
							<span class="pill">Apache Superset</span>
							<span class="pill">Pandas</span>
							<span class="pill">NumPy</span>
							<span class="pill">ETL Pipelines</span>
							<span class="pill">dbt</span>
							<span class="pill">Tableau</span>
						</div>
					</div>
					<div class="skill-group">
						<p class="skill-group-label">SYSTEMS & INFRA</p>
						<div class="skill-pills">
							<span class="pill">Kubernetes</span>
							<span class="pill">Helm</span>
							<span class="pill">Docker</span>
							<span class="pill">DigitalOcean</span>
							<span class="pill">GCP</span>
							<span class="pill">AWS</span>
							<span class="pill">FastAPI</span>
							<span class="pill">Spring Boot</span>
							<span class="pill">Redis</span>
							<span class="pill">nginx</span>
						</div>
					</div>
					<div class="skill-group">
						<p class="skill-group-label">LANGUAGES & TOOLS</p>
						<div class="skill-pills">
							<span class="pill">Python</span>
							<span class="pill">TypeScript</span>
							<span class="pill">Java</span>
							<span class="pill">SQL</span>
							<span class="pill">React</span>
							<span class="pill">Git</span>
							<span class="pill">Linux</span>
							<span class="pill">OSMnx</span>
							<span class="pill">NetworkX</span>
						</div>
					</div>
				</div>
			</div>
		</div>

		<div class="divider"></div>

		<!-- ── EXPERIENCE ──────────────────────────────────── -->
		<div class="section-grid">
			<div class="section-label-col">
				<p class="section-label">EXPERIENCE</p>
			</div>
			<div class="section-content">
				<div class="exp-list">
					<div class="exp-row">
						<div class="exp-left">
							<p class="exp-date">Jan 2026 — Now</p>
						</div>
						<div class="exp-right">
							<p class="exp-org">Ascend Cargo Systems</p>
							<p class="exp-role">Full Stack Data Analytics Engineering Intern</p>
							<ul class="exp-bullets">
								<li>Led integration of an agentic AI chatbot into Apache Superset, enabling clients to autonomously query data via natural language and accelerating time-to-insight.</li>
								<li>Built the company's first data warehouse and ETL pipelines over a production MySQL schema, creating a structured data foundation for downstream analytics and ML.</li>
								<li>Developed analytical dashboards and SQL reporting queries surfacing KPIs such as tender acceptance rate and late shipment aging.</li>
								<li>Deployed an embedded BI environment on Kubernetes with role-based access and Row Level Security for governed, client-specific data visibility.</li>
							</ul>
						</div>
					</div>
					<div class="exp-row">
						<div class="exp-left">
							<p class="exp-date">May 2024 — Jul 2024</p>
						</div>
						<div class="exp-right">
							<p class="exp-org">Virginia Tech</p>
							<p class="exp-role">Research Assistant</p>
							<ul class="exp-bullets">
								<li>Reduced the research paper review cycle from 14 days to 2 by developing Python automation scripts with Pandas and regex-based parsing, improving workflow efficiency by 85%.</li>
								<li>Applied NLP classification models using scikit-learn and spaCy to automatically categorize academic documents, reducing manual review time by 70%.</li>
								<li>Automated data collection and preprocessing pipelines with BeautifulSoup, Pandas, and NLTK, creating scalable reproducible workflows for faculty research.</li>
							</ul>
						</div>
					</div>
					<div class="exp-row">
						<div class="exp-left">
							<p class="exp-date">Jan 2023 — Jan 2024</p>
						</div>
						<div class="exp-right">
							<p class="exp-org">TIFR Mumbai</p>
							<p class="exp-role">Data Scientist & Researcher</p>
							<ul class="exp-bullets">
								<li>Designed and executed multi-agent RL simulations in PyTorch, managing large-scale experimental data in both NoSQL and relational SQL formats.</li>
								<li>Engineered a Neuro Evolution-based deep RL model improving training efficiency by 85% over baseline and reducing computational resource consumption.</li>
								<li>Leveraged Hadoop and Apache Spark for distributed data preprocessing and analysis across simulation workloads.</li>
							</ul>
						</div>
					</div>
				</div>
			</div>
		</div>

		<div class="divider"></div>

		<!-- ── BEYOND WORK ─────────────────────────────────── -->
		<div class="section-grid">
			<div class="section-label-col">
				<p class="section-label">BEYOND WORK</p>
			</div>
			<div class="section-content">
				<div class="beyond-grid">
					<div class="beyond-card">
						<div class="beyond-icon">🥾</div>
						<p class="beyond-title">Hiking & National Parks</p>
						<p class="beyond-desc">Colorado has been good to me — I've been working my way through the state's national parks and fourteeners. There's something about being in the mountains that resets everything. Rocky Mountain NP is a regular, but I'm always planning the next one.</p>
					</div>
					<div class="beyond-card">
						<div class="beyond-icon">✈️</div>
						<p class="beyond-title">Exploring New Places</p>
						<p class="beyond-desc">I think I'm drawn to places that feel different from where I've been. I travel whenever I can, usually with no real plan and a vague list of trails and food spots.</p>
					</div>
				</div>
			</div>
		</div>

	</main>

</BaseLayout>

<style>
/* ── HEADER ──────────────────────────────────────────────── */
.about-header {
	display: grid;
	grid-template-columns: 1fr 1fr;
	gap: 3rem;
	padding: 2.5rem 3rem 2rem;
	border-bottom: 1px solid var(--border-color);
	align-items: end;
}

.eyebrow {
	font-size: 0.6875rem;
	font-weight: 600;
	letter-spacing: 2.5px;
	color: var(--gray-400);
	margin-bottom: 0.5rem;
}

.about-title {
	font-size: clamp(2.5rem, 5vw, 4.5rem);
	font-weight: 500;
	color: var(--gray-0);
	letter-spacing: -0.04em;
	line-height: 0.95;
}

.accent { color: var(--accent); }

.about-tagline {
	font-size: 1rem;
	color: var(--gray-300);
	line-height: 1.6;
	margin-bottom: 1.25rem;
}

.contact-row {
	display: flex;
	gap: 1.5rem;
	flex-wrap: wrap;
}

.contact-link {
	font-size: 0.8125rem;
	color: var(--gray-400);
	text-decoration: none;
	transition: color var(--theme-transition);
}
.contact-link:hover { color: var(--gray-0); }
.accent-link { color: var(--accent); border-bottom: 1.5px solid var(--accent); padding-bottom: 1px; }
.accent-link:hover { color: var(--accent-light); border-color: var(--accent-light); }

/* ── BODY ────────────────────────────────────────────────── */
.about-body {
	padding: 0 3rem 5rem;
}

.divider {
	border: none;
	border-top: 1px solid var(--border-color);
	margin: 0;
}

.section-grid {
	display: grid;
	grid-template-columns: 160px 1fr;
	gap: 3rem;
	padding: 2.5rem 0;
}

.section-label {
	font-size: 0.625rem;
	font-weight: 600;
	letter-spacing: 2px;
	color: var(--gray-500);
	text-transform: uppercase;
	padding-top: 4px;
}

/* ── BACKGROUND ──────────────────────────────────────────── */
.bio-para {
	font-size: 0.9375rem;
	color: var(--gray-200);
	line-height: 1.85;
	margin-bottom: 1.25rem;
	max-width: 60ch;
}
.bio-para:last-child { margin-bottom: 0; }

/* ── EDUCATION ───────────────────────────────────────────── */
.edu-grid {
	display: grid;
	grid-template-columns: 1fr 1fr 1fr;
	gap: 1px;
	background: var(--border-color);
	border: 1px solid var(--border-color);
	border-radius: 10px;
	overflow: hidden;
}

.edu-card {
	background: var(--bg-surface);
	padding: 1.25rem;
}

.edu-date {
	font-size: 0.6875rem;
	font-weight: 600;
	color: var(--accent);
	letter-spacing: 0.3px;
	margin-bottom: 6px;
}

.edu-school {
	font-size: 0.9375rem;
	font-weight: 500;
	color: var(--gray-0);
	margin-bottom: 3px;
	line-height: 1.3;
}

.edu-degree {
	font-size: 0.8125rem;
	color: var(--gray-300);
	margin-bottom: 4px;
	line-height: 1.4;
}

.edu-detail {
	font-size: 0.75rem;
	color: var(--gray-500);
}

/* ── SKILLS ──────────────────────────────────────────────── */
.skills-grid {
	display: grid;
	grid-template-columns: 1fr 1fr;
	gap: 2rem;
}

.skill-group-label {
	font-size: 0.625rem;
	font-weight: 600;
	letter-spacing: 1.5px;
	color: var(--gray-400);
	text-transform: uppercase;
	margin-bottom: 0.75rem;
}

.skill-pills {
	display: flex;
	flex-wrap: wrap;
	gap: 5px;
}

.pill {
	font-size: 0.75rem;
	padding: 4px 10px;
	border-radius: 4px;
	background: var(--gray-700);
	color: var(--gray-200);
	border: 1px solid var(--gray-600);
}

/* ── EXPERIENCE ──────────────────────────────────────────── */
.exp-list {
	display: flex;
	flex-direction: column;
	gap: 0;
}

.exp-row {
	display: grid;
	grid-template-columns: 120px 1fr;
	gap: 2rem;
	padding: 1.5rem 0;
	border-bottom: 1px solid var(--border-color);
}
.exp-row:last-child { border-bottom: none; }

.exp-date {
	font-size: 0.75rem;
	font-weight: 600;
	color: var(--accent);
	padding-top: 3px;
}

.exp-org {
	font-size: 0.9375rem;
	font-weight: 500;
	color: var(--gray-0);
	margin-bottom: 2px;
}

.exp-role {
	font-size: 0.8125rem;
	color: var(--gray-400);
	margin-bottom: 0.5rem;
}

.exp-bullets {
	list-style: none;
	padding: 0;
	margin: 0;
	display: flex;
	flex-direction: column;
	gap: 0.5rem;
}

.exp-bullets li {
	font-size: 0.8125rem;
	color: var(--gray-400);
	line-height: 1.65;
	padding-left: 1rem;
	position: relative;
}

.exp-bullets li::before {
	content: '—';
	position: absolute;
	left: 0;
	color: var(--accent);
	font-size: 0.75rem;
}

/* ── BEYOND WORK ─────────────────────────────────────────── */
.beyond-grid {
	display: grid;
	grid-template-columns: 1fr 1fr;
	gap: 1px;
	background: var(--border-color);
	border: 1px solid var(--border-color);
	border-radius: 10px;
	overflow: hidden;
}

.beyond-card {
	background: var(--bg-surface);
	padding: 1.5rem 1.25rem;
	display: flex;
	flex-direction: column;
	gap: 0.5rem;
}

.beyond-icon {
	font-size: 1.5rem;
	margin-bottom: 0.25rem;
}

.beyond-title {
	font-size: 0.9375rem;
	font-weight: 500;
	color: var(--gray-0);
	line-height: 1.3;
}

.beyond-desc {
	font-size: 0.8125rem;
	color: var(--gray-400);
	line-height: 1.7;
}

/* ── RESPONSIVE ──────────────────────────────────────────── */
@media (max-width: 50em) {
	.about-header {
		grid-template-columns: 1fr;
		padding: 2rem 1.5rem 1.5rem;
		gap: 1.5rem;
	}
	.about-body { padding: 0 1.5rem 3rem; }
	.section-grid { grid-template-columns: 1fr; gap: 1rem; }
	.edu-grid { grid-template-columns: 1fr; }
	.skills-grid { grid-template-columns: 1fr; }
	.exp-row { grid-template-columns: 1fr; gap: 0.5rem; }
	.beyond-grid { grid-template-columns: 1fr; }
}
</style>
