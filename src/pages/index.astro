---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;

const projects = (await getCollection('work'))
	.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
	.slice(0, 6);

const newsItems = (await getCollection('news'))
	.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
	.slice(0, 8);

const badgeClass: Record<string, string> = {
	Research:    'badge-research',
	Work:        'badge-work',
	Education:   'badge-school',
	Publication: 'badge-research',
	Award:       'badge-work',
	Speaking:    'badge-school',
};
---

<BaseLayout title="Rhea Nair" description="ML Engineer & Data Scientist">

	<!-- ── HERO ─────────────────────────────────────────── -->
	<section class="hero">
		<div class="hero-name-block">
			<p class="eyebrow">ML ENGINEER · DATA SCIENTIST · CU BOULDER</p>
			<h1 class="hero-name">Rhea<br /><span class="accent">Nair.</span></h1>
		</div>
		<div class="hero-bottom">
			<div class="hero-bottom-left">
				<p class="hero-bio">
					I build systems that learn from fine-tuning vision models on CULane
					to data infrastructure that ships real cargo. Hard problems at the edge
					of ML and systems.
				</p>
				<div class="hero-btns">
					<a href={`${base}work/`} class="btn-fill">View work</a>
					<a href="https://www.linkedin.com/in/rheanair07" target="_blank" rel="noopener" class="btn-ghost">LinkedIn →</a>
					<a href="https://github.com/rheanair7" target="_blank" rel="noopener" class="btn-ghost">GitHub →</a>
				</div>
			</div>
			<div class="photo-wrap">
				<div class="photo-circle">
					<img
						src={`${import.meta.env.BASE_URL}assets/potrait.jpg`}
						alt="Rhea Nair"
						width="480"
						height="560"
						class="hero-photo"
					/>
				</div>
				<div class="avail">
					<span class="avail-dot"></span>
					<span>Open to full-time · Bay Area / Remote</span>
				</div>
			</div>
		</div>
	</section>

	<!-- ── TICKER ────────────────────────────────────────── -->
	<div class="ticker-wrap" aria-hidden="true">
		<div class="ticker-inner">
			{['PyTorch','·','Computer Vision','·','Transformers','·','SQL / ETL','·',
			  'Kubernetes','·','HuggingFace','·','Grad-CAM','·','FastAPI','·',
			  'Apache Superset','·','XGBoost','·','DigitalOcean','·','React','·',
			  'PyTorch','·','Computer Vision','·','Transformers','·','SQL / ETL','·',
			  'Kubernetes','·','HuggingFace','·','Grad-CAM','·','FastAPI','·',
			  'Apache Superset','·','XGBoost','·','DigitalOcean','·','React','·',
			].map((item) => (
				<span class:list={['ti', { accent: item !== '·' && Math.random() > 0.6 }]}>
					{item}
				</span>
			))}
		</div>
	</div>

	<main class="main-body">

		<!-- ── WORK BENTO ─────────────────────────────────── -->
		<p class="section-label">SELECTED WORK</p>
		<div class="bento">
			{projects.map((project) => (
				<a
					href={`${base}work/${project.id.replace(/\.md$/, '')}/`}
					class="bento-card"
				>
					<p class="card-title">{project.data.title}</p>
					<p class="card-desc">{project.data.description}</p>
					<div class="card-pills">
						{project.data.tags.map(tag => (
							<span class="card-pill">{tag}</span>
						))}
					</div>
					<span class="card-arrow">↗</span>
				</a>
			))}
		</div>

		<!-- ── RECENT NEWS ────────────────────────────────── -->
		<p class="section-label" style="margin-top:2.5rem">RECENT NEWS</p>
		<div class="news-grid">
			{newsItems.map(item => (
				<div class="news-card">
					<div class="news-meta">
						<time class="news-date">
							{item.data.publishDate.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}
						</time>
						<span class:list={['news-badge', badgeClass[item.data.category] ?? 'badge-work']}>
							{item.data.category}
						</span>
					</div>
					<p class="news-text" set:html={item.data.description} />
				</div>
			))}
		</div>

		<!-- ── EXPERIENCE ──────────────────────────────────── -->
		<p class="section-label" style="margin-top:2.5rem">EXPERIENCE</p>
		<div class="exp-grid">
			<div class="exp-card">
				<p class="exp-date">2025 — NOW</p>
				<p class="exp-org">Ascend Cargo Systems</p>
				<p class="exp-role">Data Analytics Engineering Intern</p>
			</div>
			<div class="exp-card">
				<p class="exp-date">2024 — 2025</p>
				<p class="exp-org">Virginia Tech</p>
				<p class="exp-role">NLP Research Assistant</p>
			</div>
			<div class="exp-card">
				<p class="exp-date">2022 — 2023</p>
				<p class="exp-org">TIFR Mumbai</p>
				<p class="exp-role">Multi-Agent RL Research Intern</p>
			</div>
		</div>

	</main>
</BaseLayout>

<style>
/* ── HERO ──────────────────────────────────────────────── */
.hero {
	padding: 2.5rem 3rem;
	border-bottom: 1px solid var(--border-color);
	display: flex;
	flex-direction: column;
	gap: 1.5rem;
	overflow: visible;
}

.hero-name-block {
	display: flex;
	flex-direction: column;
	gap: 0.75rem;
}

.eyebrow {
	font-size: 0.6875rem;
	font-weight: 600;
	letter-spacing: 2.5px;
	color: var(--gray-400);
}

.hero-name {
	font-size: clamp(3rem, 6vw, 5rem);
	font-weight: 500;
	color: var(--gray-0);
	letter-spacing: -0.04em;
	line-height: 0.9;
}

.accent { color: var(--accent); }

.hero-bottom {
	display: flex;
	align-items: center;
	justify-content: space-between;
	gap: 2rem;
}

.hero-bottom-left {
	display: flex;
	flex-direction: column;
	gap: 1.25rem;
	max-width: 480px;
}

.hero-bio {
	font-size: 1rem;
	color: var(--gray-300);
	line-height: 1.8;
}

.hero-btns {
	display: flex;
	gap: 14px;
	align-items: center;
	flex-wrap: wrap;
}

.btn-fill {
	font-size: 0.875rem;
	font-weight: 500;
	background: var(--gray-0);
	color: var(--bg-surface);
	padding: 10px 22px;
	border-radius: 5px;
	text-decoration: none;
	transition: opacity var(--theme-transition);
}
.btn-fill:hover { opacity: 0.8; color: var(--bg-surface); }

.btn-ghost {
	font-size: 0.875rem;
	color: var(--gray-400);
	text-decoration: none;
	transition: color var(--theme-transition);
}
.btn-ghost:hover { color: var(--gray-0); }

.photo-wrap {
	display: flex;
	flex-direction: column;
	align-items: center;
	gap: 0.75rem;
	margin-right: 4rem;
	margin-top: -200px;
}

.photo-circle {
	width: 360px;
	height: 360px;
	border-radius: 50%;
	overflow: hidden;
	border: 3px solid var(--border-color);
	flex-shrink: 0;
	box-shadow: 0 8px 32px rgba(0,0,0,0.1);
}

.hero-photo {
	width: 100%;
	height: 100%;
	object-fit: cover;
	object-position: center 20%;
	display: block;
}

.avail {
	display: flex;
	align-items: center;
	justify-content: center;
	gap: 6px;
}
.avail-dot {
	width: 6px;
	height: 6px;
	border-radius: 50%;
	background: var(--accent);
	flex-shrink: 0;
}
.avail span:last-child {
	font-size: 0.75rem;
	color: var(--gray-400);
}

@media (max-width: 50em) {
	.hero { padding: 2rem 1.5rem; }
	.hero-bottom { flex-direction: column; align-items: flex-start; }
	.photo-wrap { margin-right: 0; margin-top: 0; }
	.photo-circle { width: 160px; height: 160px; }
}

/* ── TICKER ────────────────────────────────────────────── */
.ticker-wrap {
	overflow: hidden;
	background: var(--bg-darkest);
	border-bottom: 1px solid var(--border-color);
	padding: 8px 0;
}
.ticker-inner {
	display: inline-flex;
	gap: 2rem;
	animation: ticker 32s linear infinite;
	white-space: nowrap;
}
.ti {
	font-size: 0.6875rem;
	font-weight: 500;
	color: #555;
	letter-spacing: 0.8px;
	flex-shrink: 0;
}
.ti.accent { color: var(--accent); }
@keyframes ticker {
	0%   { transform: translateX(0); }
	100% { transform: translateX(-50%); }
}

/* ── MAIN BODY ─────────────────────────────────────────── */
.main-body { padding: 0 2.5rem 4rem; }

.section-label {
	font-size: 0.75rem;
	font-weight: 600;
	letter-spacing: 2px;
	color: var(--gray-400);
	text-transform: uppercase;
	margin-bottom: 1rem;
	margin-top: 2.5rem;
	display: block;
}

/* ── BENTO ─────────────────────────────────────────────── */
.bento {
	display: grid;
	grid-template-columns: 1fr 1fr 1fr;
	gap: 1px;
	background: var(--border-color);
	border: 1px solid var(--border-color);
	border-radius: 10px;
	overflow: hidden;
}

.bento-card {
	background: var(--bg-surface);
	padding: 1rem 1.25rem;
	display: flex;
	flex-direction: column;
	gap: 6px;
	text-decoration: none;
	position: relative;
	transition: background var(--theme-transition);
}
.bento-card:hover { background: var(--gray-800); }

.card-title {
	font-size: 0.875rem;
	font-weight: 500;
	color: var(--gray-0);
	line-height: 1.3;
	letter-spacing: -0.01em;
}

.card-desc {
	font-size: 0.75rem;
	color: var(--gray-300);
	line-height: 1.6;
	margin-bottom: 4px;
}

.card-pills {
	display: flex;
	gap: 5px;
	flex-wrap: wrap;
	margin-top: auto;
}

.card-pill {
	font-size: 0.6875rem;
	padding: 3px 10px;
	border-radius: 3px;
	background: var(--gray-700);
	color: var(--gray-200);
	border: 1px solid var(--gray-600);
}

.card-arrow {
	position: absolute;
	top: 1.1rem;
	right: 1.1rem;
	font-size: 0.75rem;
	color: var(--gray-500);
}

@media (max-width: 50em) {
	.bento { grid-template-columns: 1fr; }
}

/* ── NEWS ──────────────────────────────────────────────── */
.news-grid {
	display: flex;
	gap: 1px;
	background: var(--border-color);
	border: 1px solid var(--border-color);
	border-radius: 10px;
	overflow-x: auto;
	overflow-y: hidden;
	scrollbar-width: thin;
	scrollbar-color: var(--border-color) transparent;
}

.news-card {
	background: var(--bg-surface);
	padding: 1rem 1.25rem;
	min-width: 280px;
	max-width: 320px;
	flex-shrink: 0;
}

.news-meta {
	display: flex;
	align-items: center;
	gap: 7px;
	margin-bottom: 7px;
}

.news-date { font-size: 0.75rem; color: var(--gray-400); }

.news-badge {
	font-size: 0.6875rem;
	font-weight: 600;
	padding: 2px 8px;
	border-radius: 3px;
}
.badge-research { background: #F0DEDA; color: #7A3028; }
.badge-work     { background: #DCE8D8; color: #285020; }
.badge-school   { background: #DDD8EE; color: #302868; }

.news-text { font-size: 0.875rem; color: var(--gray-300); line-height: 1.65; }

/* ── EXPERIENCE ────────────────────────────────────────── */
.exp-grid {
	display: grid;
	grid-template-columns: 1fr 1fr 1fr;
	gap: 1px;
	background: var(--border-color);
	border: 1px solid var(--border-color);
	border-radius: 10px;
	overflow: hidden;
}

.exp-card { background: var(--bg-surface); padding: 1.1rem 1.25rem; }

.exp-date {
	font-size: 0.75rem;
	font-weight: 600;
	color: var(--accent);
	letter-spacing: 0.3px;
	margin-bottom: 5px;
}

.exp-org {
	font-size: 0.9375rem;
	font-weight: 500;
	color: var(--gray-0);
	margin-bottom: 3px;
}

.exp-role { font-size: 0.8125rem; color: var(--gray-400); line-height: 1.4; }

@media (max-width: 50em) {
	.main-body { padding: 0 1.25rem 3rem; }
	.exp-grid  { grid-template-columns: 1fr; }
	.news-grid { grid-template-columns: 1fr; }
}
</style>