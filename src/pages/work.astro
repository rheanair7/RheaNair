---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;

const projects = (await getCollection('work'))
	.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

const accentColors: Record<string, string> = {
	'PyTorch':    '#4A7C59',
	'SQL':        '#4A5E7C',
	'XGBoost':    '#7C4A4A',
	'NLP':        '#6A4A7C',
	'Automation': '#6A4A7C',
	'Analytics':  '#4A5E7C',
};

function getAccent(tags: string[]) {
	for (const tag of tags) {
		if (accentColors[tag]) return accentColors[tag];
	}
	return '#7A7060';
}
---

<BaseLayout title="Work — Rhea Nair" description="Selected projects and experiments">

	<div class="work-header">
		<div>
			<p class="eyebrow">SELECTED WORK</p>
			<h1 class="work-title">Projects</h1>
		</div>
		<p class="work-desc">ML, data engineering, and research — click any card for the full case study.</p>
	</div>

	<main class="work-body">
		<div class="project-grid">
			{projects.map((project) => {
				const accent = getAccent(project.data.tags);
				return (
					<a
						href={`${base}work/${project.id.replace(/\.md$/, '')}/`}
						class="project-card"
						style={`--card-accent: ${accent};`}
					>
						<div class="card-accent-bar"></div>
						<div class="card-body">
							<p class="card-title">{project.data.title}</p>
							<p class="card-desc">{project.data.description}</p>
						</div>
						<div class="card-footer">
							<div class="card-tags">
								{project.data.tags.slice(0, 3).map(tag => (
									<span class="card-tag">{tag}</span>
								))}
							</div>
							<span class="card-year">{project.data.publishDate.getFullYear()}</span>
						</div>
					</a>
				);
			})}
		</div>
	</main>

</BaseLayout>

<style>
.work-header {
	display: flex;
	align-items: flex-end;
	justify-content: space-between;
	gap: 3rem;
	padding: 2.5rem 3rem 2rem;
	border-bottom: 1px solid var(--border-color);
}

.eyebrow {
	font-size: 0.6875rem;
	font-weight: 600;
	letter-spacing: 2.5px;
	color: var(--gray-400);
	margin-bottom: 0.5rem;
}

.work-title {
	font-size: clamp(2.5rem, 5vw, 4rem);
	font-weight: 500;
	color: var(--gray-0);
	letter-spacing: -0.04em;
	line-height: 1;
}

.work-desc {
	font-size: 0.9375rem;
	color: var(--gray-400);
	line-height: 1.7;
	max-width: 36ch;
	text-align: right;
}

.work-body {
	padding: 2rem 3rem 4rem;
}

.project-grid {
	display: grid;
	grid-template-columns: repeat(3, 1fr);
	gap: 1px;
	background: var(--border-color);
	border: 1px solid var(--border-color);
	border-radius: 10px;
	overflow: hidden;
}

.project-card {
	background: var(--bg-surface);
	display: flex;
	flex-direction: column;
	text-decoration: none;
	transition: background var(--theme-transition);
	position: relative;
	overflow: hidden;
}
.project-card:hover { background: var(--gray-800); }
.project-card:hover .card-accent-bar { opacity: 1; }
.project-card:hover .card-title { color: var(--card-accent); }

.card-accent-bar {
	height: 3px;
	background: var(--card-accent);
	opacity: 0.4;
	transition: opacity var(--theme-transition);
}

.card-body {
	padding: 1.25rem 1.25rem 0.75rem;
	flex: 1;
	display: flex;
	flex-direction: column;
	gap: 0.5rem;
}

.card-title {
	font-size: 0.9375rem;
	font-weight: 500;
	color: var(--gray-0);
	line-height: 1.35;
	letter-spacing: -0.01em;
	transition: color var(--theme-transition);
}

.card-desc {
	font-size: 0.75rem;
	color: var(--gray-400);
	line-height: 1.6;
}

.card-footer {
	padding: 0.75rem 1.25rem 1.25rem;
	display: flex;
	justify-content: space-between;
	align-items: flex-end;
	margin-top: auto;
}

.card-tags {
	display: flex;
	gap: 4px;
	flex-wrap: wrap;
}

.card-tag {
	font-size: 0.625rem;
	padding: 2px 7px;
	border-radius: 3px;
	background: var(--gray-700);
	color: var(--gray-300);
	border: 1px solid var(--gray-600);
}

.card-year {
	font-size: 0.6875rem;
	color: var(--gray-500);
	flex-shrink: 0;
}

@media (max-width: 50em) {
	.work-header {
		flex-direction: column;
		align-items: flex-start;
		padding: 2rem 1.5rem 1.5rem;
		gap: 1rem;
	}
	.work-desc { text-align: left; }
	.work-body { padding: 1.5rem 1.5rem 3rem; }
	.project-grid { grid-template-columns: 1fr; }
}
</style>
